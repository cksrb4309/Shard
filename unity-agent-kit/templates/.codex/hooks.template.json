{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File ./.codex/hooks/guard-assets-check.ps1"
          }
        ]
      },
      {
        "matcher": "Bash|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File ./.codex/hooks/guard-shell-check.ps1"
          }
        ]
      }
    ]
  }
}
